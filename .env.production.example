# ==============================================================================
# SRI CHAKRA YOGA SANCTUARY - PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' on your production server and fill in real values.
# ==============================================================================

# PostgreSQL Database Credentials
POSTGRES_DB=ashram_media_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeThisToAVeryStrongRandomDatabasePassword2026!

# Sacred JWT Secret (Must be a long, secure random alphanumeric string >= 256 bits)
JWT_SECRET=ReplaceWithYourHighEntropySacredJwtSecretKey2026!
JWT_EXPIRATION=86400000

# CORS Configuration (Allowed domain origins separated by commas)
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://YOUR_VPS_IP,https://srichakrayoga.org,https://www.srichakrayoga.org

# Razorpay Test / Live API Keys
RAZORPAY_KEY_ID=rzp_test_YOUR_ACTUAL_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_ACTUAL_RAZORPAY_SECRET
